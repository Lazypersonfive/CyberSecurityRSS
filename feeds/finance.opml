<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Finance &amp; Payments Feeds</title>
    <!--
      Focus: top global payment networks + major digital wallets.
      Strategy:
        - Use official investor/newsroom RSS where it exists (Visa, Mastercard).
        - For networks without public RSS (PayPal, Amex, JCB, Alipay, Tenpay),
          use Google News RSS search as a unified fallback.
        - Keep Payments Dive + PYMNTS as third-party editorial lens.
      TODO (pending user): add wechat2rss hashes for 蚂蚁集团 / 支付宝 / 腾讯金融科技 / 财付通 official accounts.
    -->
  </head>
  <body>
    <outline text="Card Networks" title="Card Networks">
      <outline type="rss" text="Visa Investor Press" title="Visa Investor Press" xmlUrl="https://investor.visa.com/rss/PressRelease.aspx?CompanyID=VISA" htmlUrl="https://investor.visa.com/news/"/>
      <outline type="rss" text="Mastercard Investor Press" title="Mastercard Investor Press" xmlUrl="https://investor.mastercard.com/rss/PressRelease.aspx?CompanyID=MASTERCARD" htmlUrl="https://investor.mastercard.com/news-and-events/news-releases/"/>
      <outline type="rss" text="American Express Investor Press" title="American Express Investor Press" xmlUrl="https://ir.americanexpress.com/rss/PressRelease.aspx?CompanyID=AXP" htmlUrl="https://ir.americanexpress.com/"/>
      <outline type="rss" text="JCB (Google News)" title="JCB (Google News)" xmlUrl="https://news.google.com/rss/search?q=%22JCB%22+(payments+OR+card+OR+network)&amp;hl=en-US&amp;gl=US&amp;ceid=US:en" htmlUrl="https://www.global.jcb/en/press/"/>
    </outline>
    <outline text="Digital Wallets" title="Digital Wallets">
      <outline type="rss" text="PayPal Investor Press" title="PayPal Investor Press" xmlUrl="https://investor.pypl.com/rss/PressRelease.aspx?CompanyID=PYPL" htmlUrl="https://investor.pypl.com/"/>
      <outline type="rss" text="Alipay / Ant Group (Google News)" title="Alipay / Ant Group (Google News)" xmlUrl="https://news.google.com/rss/search?q=(%22Alipay%22+OR+%22Ant+Group%22)+(payments+OR+fintech)&amp;hl=en-US&amp;gl=US&amp;ceid=US:en" htmlUrl="https://www.alipay.com/"/>
      <outline type="rss" text="WeChat Pay / Tenpay (Google News)" title="WeChat Pay / Tenpay (Google News)" xmlUrl="https://news.google.com/rss/search?q=(%22WeChat+Pay%22+OR+%22Tenpay%22+OR+%22Tencent+Financial%22)&amp;hl=en-US&amp;gl=US&amp;ceid=US:en" htmlUrl="https://pay.weixin.qq.com/"/>
    </outline>
    <outline text="Official Institutions" title="Official Institutions">
      <outline type="rss" text="Federal Reserve Press Releases" title="Federal Reserve Press Releases" xmlUrl="https://www.federalreserve.gov/feeds/press_all.xml" htmlUrl="https://www.federalreserve.gov/newsevents/pressreleases.htm"/>
      <outline type="rss" text="European Central Bank Releases" title="European Central Bank Releases" xmlUrl="https://www.ecb.europa.eu/rss/press.html" htmlUrl="https://www.ecb.europa.eu/press/html/index.en.html"/>
      <outline type="rss" text="BIS Press Releases" title="BIS Press Releases" xmlUrl="https://www.bis.org/doclist/all_pressrels.rss" htmlUrl="https://www.bis.org/press/index.htm"/>
      <outline type="rss" text="Stripe Blog" title="Stripe Blog" xmlUrl="https://stripe.com/blog/feed.rss" htmlUrl="https://stripe.com/blog"/>
    </outline>
    <outline text="Editorial Lens" title="Editorial Lens">
      <outline type="rss" text="Payments Dive" title="Payments Dive" xmlUrl="https://www.paymentsdive.com/feeds/news/" htmlUrl="https://www.paymentsdive.com/"/>
      <outline type="rss" text="PYMNTS" title="PYMNTS" xmlUrl="https://www.pymnts.com/feed/" htmlUrl="https://www.pymnts.com/"/>
      <outline type="rss" text="Finextra Headlines" title="Finextra Headlines" xmlUrl="https://www.finextra.com/rss/headlines.aspx" htmlUrl="https://www.finextra.com/"/>
      <outline type="rss" text="The Fintech Times" title="The Fintech Times" xmlUrl="https://thefintechtimes.com/feed/" htmlUrl="https://thefintechtimes.com/"/>
      <outline type="rss" text="Finance Magnates Fintech" title="Finance Magnates Fintech" xmlUrl="https://www.financemagnates.com/fintech/feed/" htmlUrl="https://www.financemagnates.com/fintech/"/>
    </outline>
    <outline text="Chinese Wallets (TODO)" title="Chinese Wallets (TODO)">
      <outline type="rss" text="Google News 中文金融科技" title="Google News 中文金融科技" xmlUrl="https://news.google.com/rss/search?q=(%22金融科技%22+OR+%22数字人民币%22+OR+%22支付宝%22+OR+%22微信支付%22+OR+%22稳定币%22+OR+%22跨境支付%22)&amp;hl=zh-CN&amp;gl=CN&amp;ceid=CN:zh-Hans" htmlUrl="https://news.google.com/"/>
      <!-- 待补：wechat2rss hash for 蚂蚁集团 / 支付宝 / 腾讯金融科技 / 财付通 -->
    </outline>
  </body>
</opml>
